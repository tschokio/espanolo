{
  "name": "espanolo",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted Spanish grammar learning platform",
  "scripts": {
    "dev": "NODE_ENV=development node server/index.js",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "test": "node --test",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:seed:learning-loop": "node prisma/seed-learning-loop.js",
    "db:seed:lesson-practice": "node prisma/seed-lesson-practice.js",
    "assets:audit": "node scripts/audit-assets.js",
    "spanish:audit": "node scripts/audit-spanish.js"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
